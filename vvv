document.addEventListener('DOMContentLoaded', function () {
  const cards = document.querySelectorAll('#PriceList details');

  // Reveal saat scroll
  const revealCards = () => {
    const triggerBottom = window.innerHeight * 0.9;
    cards.forEach(card => {
      const rect = card.getBoundingClientRect();
      if (rect.top < triggerBottom) {
        card.classList.add('visible');
      }
    });
  };

  // Animasikan saat dibuka
  cards.forEach(card => {
    const summary = card.querySelector('summary');
    summary.addEventListener('click', function () {
      // Tutup kartu lain (accordion style)
      cards.forEach(other => {
        if (other !== card) {
          other.removeAttribute('open');
        }
      });

      // Scroll smooth
      setTimeout(() => {
        card.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 300);
    });
  });

  // Trigger pertama kali
  window.addEventListener('scroll', revealCards);
  window.addEventListener('load', revealCards);
});

document.addEventListener("DOMContentLoaded", function () {
  const aboutSection = document.querySelector("#about");
  const aboutText = aboutSection.querySelectorAll("p");
  const aboutTitle = aboutSection.querySelector("h2");
  const aboutImg = aboutSection.querySelector("img");

  // Awal: sembunyikan semua elemen dengan opacity
  aboutText.forEach(p => {
    p.style.opacity = 0;
    p.style.transform = "translateY(20px)";
    p.style.transition = "opacity 0.6s ease, transform 0.6s ease";
  });

  aboutTitle.style.opacity = 0;
  aboutTitle.style.transition = "opacity 0.8s ease";

  aboutImg.style.opacity = 0;
  aboutImg.style.transition = "opacity 0.8s ease";

  const revealAbout = () => {
    const rect = aboutSection.getBoundingClientRect();
    if (rect.top < window.innerHeight - 100) {
      aboutTitle.style.opacity = 1;
      aboutImg.style.opacity = 1;

      aboutText.forEach((p, index) => {
        setTimeout(() => {
          p.style.opacity = 1;
          p.style.transform = "translateY(0)";
        }, index * 300); // Delay antar paragraf
      });

      window.removeEventListener("scroll", revealAbout);
    }
  };

  window.addEventListener("scroll", revealAbout);
  revealAbout();
});



